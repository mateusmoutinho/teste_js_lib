{
  "name": "teste-js-lib",
  "version": "1.0.0",
  "description": "A minimal TypeScript library and CLI boilerplate",
  "main": "dist/lib.js",
  "types": "dist/lib.d.ts",
  "bin": {
    "teste-js-cli": "dist/cli.js"
  },
  "scripts": {
    "build": "npm run build:lib && npm run build:cli",
    "build:lib": "tsc -p tsconfig.lib.json",
    "build:cli": "tsc -p tsconfig.cli.json",
    "prepare": "npm run build"
  },
  "files": [
    "dist"
  ],
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  }
}
